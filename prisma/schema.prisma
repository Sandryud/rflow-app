// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  name         String
  passwordHash String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  memberships  Membership[]
  releases     Release[]

  createdChecklistItems ChecklistItem[] @relation("ChecklistItemCreatedBy")

  assignedChecklistItems ChecklistItem[] @relation("ChecklistItemAssignedTo")

  completedChecklistItems ChecklistItem[] @relation("ChecklistItemCompletedBy")
  reviewerApprovals       Approval[]
}

enum MembershipRole {
  OWNER
  MANAGER
  DEVELOPER
  QA
  VIEWER
}

model Membership {
  id             String         @id @default(uuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  role           MembershipRole
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([userId, organizationId])
}

model Organization {
  id          String       @id @default(uuid())
  name        String       @db.VarChar(100)
  description String?      @db.VarChar(400)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  memberships Membership[]
  projects    Project[]
}

model Project {
  id             String        @id @default(uuid())
  name           String        @db.VarChar(100)
  description    String?       @db.VarChar(400)
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  environments   Environment[]
  releases       Release[]

  @@unique([organizationId, name])
}

model Environment {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(100)
  description String?   @db.VarChar(400)
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  isActive    Boolean   @default(true)
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  releases    Release[]

  @@unique([projectId, name])
}

enum ReleaseStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
  RELEASED
  CANCELLED
}

model Release {
  id               String          @id @default(uuid())
  version          String          @db.VarChar(50)
  name             String          @db.VarChar(100)
  description      String?         @db.VarChar(400)
  status           ReleaseStatus   @default(DRAFT)
  createdByUserId  String
  createdBy        User            @relation(fields: [createdByUserId], references: [id])
  plannedReleaseAt DateTime?
  projectId        String
  environmentId    String
  environment      Environment     @relation(fields: [environmentId], references: [id])
  project          Project         @relation(fields: [projectId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?
  releaseTasks     ReleaseTask[]
  checkListItems   ChecklistItem[]
  approvals        Approval[]

  @@unique([projectId, version])
}

model ReleaseTask {
  id          String   @id @default(uuid())
  releaseId   String
  release     Release  @relation(fields: [releaseId], references: [id])
  name        String   @db.VarChar(200)
  key         String   @db.VarChar(50)
  description String?  @db.VarChar(400)
  url         String?  @db.VarChar(400)
  type        String?  @db.VarChar(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([releaseId, key])
}

enum ChecklistItemStatus {
  TODO
  DONE
  BLOCKED
}

model ChecklistItem {
  id          String              @id @default(uuid())
  releaseId   String
  release     Release             @relation(fields: [releaseId], references: [id])
  title       String              @db.VarChar(200)
  description String?             @db.VarChar(400)
  status      ChecklistItemStatus @default(TODO)
  isRequired  Boolean             @default(false)
  comment     String?             @db.VarChar(500)

  assignedToUserId String?
  assignedTo       User?   @relation("ChecklistItemAssignedTo", fields: [assignedToUserId], references: [id])

  createdByUserId String
  createdBy       User   @relation("ChecklistItemCreatedBy", fields: [createdByUserId], references: [id])

  completedByUserId String?
  completedBy       User?   @relation("ChecklistItemCompletedBy", fields: [completedByUserId], references: [id])

  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([releaseId, title])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Approval {
  id             String         @id @default(uuid())
  releaseId      String
  release        Release        @relation(fields: [releaseId], references: [id])
  reviewerUserId String
  reviewer       User           @relation(fields: [reviewerUserId], references: [id])
  status         ApprovalStatus @default(PENDING)
  comment        String?        @db.VarChar(400)
  decidedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([releaseId, reviewerUserId])
}
